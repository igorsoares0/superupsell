{% comment %} ══════════════════════════════════════════
   POSITIONING SCRIPT — runs synchronously BEFORE superupsell.js (defer)
   ══════════════════════════════════════════ {% endcomment %}
<script>
(function(){
  /* Check if a block-placed widget already exists for a given surface */
  function hasBlock(surface, container) {
    var all = document.querySelectorAll('.superupsell-widget[data-surface="' + surface + '"]');
    for (var i = 0; i < all.length; i++) {
      if (!container.contains(all[i])) return true;
    }
    return false;
  }

  /* Move a widget from its hidden container into the page */
  function inject(container, ref, position) {
    var widget = container.firstElementChild;
    if (!widget) return;
    container.removeChild(widget);
    container.remove();
    ref.insertAdjacentElement(position, widget);
  }

  /* ── Product page widget ── */
  var pp = document.getElementById('su-auto-pp');
  if (pp) {
    if (hasBlock('product_page', pp)) {
      pp.remove();
    } else {
      var ppRef =
        document.querySelector('product-form') ||
        document.querySelector('form[action*="/cart/add"]') ||
        document.querySelector('.product__info-wrapper') ||
        document.querySelector('.product-single__meta') ||
        document.querySelector('.product__meta');
      if (ppRef) {
        inject(pp, ppRef, 'beforebegin');
      } else {
        /* Can't find product form — show in place as last resort */
        pp.style.display = '';
      }
    }
  }

  /* ── Popup ── */
  var popup = document.getElementById('su-auto-popup');
  if (popup) {
    /* If the standalone popup embed already rendered, skip ours */
    if (document.getElementById('superupsell-popup-data')) {
      popup.remove();
    } else {
      /* Rename so initPopup() in superupsell.js picks it up */
      popup.id = 'superupsell-popup-data';
    }
  }

  /* ── Cart widget ── */
  var cart = document.getElementById('su-auto-cart');
  if (cart) {
    if (hasBlock('cart', cart)) {
      cart.remove();
    } else {
      var cartRef =
        document.querySelector('cart-items') ||
        document.querySelector('.cart__contents') ||
        document.querySelector('.cart__items') ||
        document.querySelector('form[action="/cart"]') ||
        document.querySelector('.cart') ||
        document.querySelector('#cart') ||
        document.querySelector('#MainContent main') ||
        document.querySelector('#MainContent') ||
        document.querySelector('main');
      if (cartRef) {
        inject(cart, cartRef, 'beforebegin');
      } else {
        cart.style.display = '';
      }
    }
  }
})();
</script>
<script src="{{ 'superupsell.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "SuperUpsell (auto)",
  "target": "body",
  "settings": []
}
{% endschema %}
