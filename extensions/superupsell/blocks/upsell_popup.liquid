{% if template contains 'product' %}
  {% assign offer = shop.metafields["$app:superupsell"]["popup"].value %}

  {% if offer and offer.isActive %}
    {% comment %} Target matching {% endcomment %}
    {% assign should_show = false %}

    {% if offer.targetMode == 'all_products' %}
      {% assign should_show = true %}
    {% elsif offer.targetMode == 'specific_products' %}
      {% for target in offer.targets %}
        {% assign target_id = target.targetId | split: '/' | last | plus: 0 %}
        {% if product.id == target_id %}
          {% assign should_show = true %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% elsif offer.targetMode == 'collections' %}
      {% for collection in product.collections %}
        {% for target in offer.targets %}
          {% assign target_id = target.targetId | split: '/' | last | plus: 0 %}
          {% if collection.id == target_id %}
            {% assign should_show = true %}
            {% break %}
          {% endif %}
        {% endfor %}
        {% if should_show %}{% break %}{% endif %}
      {% endfor %}
    {% endif %}

    {% if should_show %}
      {% assign radius = offer.cornerRadius | default: 8 %}
      {% assign card_radius = radius | minus: 2 | at_least: 0 %}
      {% assign img_radius = card_radius | minus: 2 | at_least: 0 %}

      <div
        id="superupsell-popup-data"
        data-delay="{{ block.settings.delay_seconds | default: 3 }}"
        style="display:none;"
      >
        <div class="superupsell-popup-content" style="background:{{ offer.backgroundColor | default: '#fff' }};font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">

          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <div style="font-size:{{ offer.titleSize | default: 18 }}px;font-weight:600;color:#1a1a1a;">
              {{ offer.titleText | default: 'You may also like' }}
            </div>
            <button class="superupsell-popup-close" style="background:none;border:none;font-size:24px;cursor:pointer;color:#666;padding:0 4px;">×</button>
          </div>

          {% if offer.discountLabel != blank and offer.discountPercentage > 0 %}
            <div style="margin-bottom:10px;">
              <span style="display:inline-block;background:#e53e3e;color:#fff;font-size:11px;font-weight:600;padding:2px 8px;border-radius:4px;">
                {{ offer.discountLabel }} — {{ offer.discountPercentage }}% off
              </span>
            </div>
          {% endif %}

          <div style="display:flex;flex-direction:column;gap:10px;">
            {% for p in offer.products %}
              {% assign prod = all_products[p.handle] %}
              {% if prod and prod.available %}
                {% assign original_price = prod.price %}
                {% assign discount_amount = original_price | times: offer.discountPercentage | divided_by: 100 %}
                {% assign discounted_price = original_price | minus: discount_amount %}
                {% assign first_variant = prod.selected_or_first_available_variant %}
                {% assign btn_radius = card_radius | minus: 2 | at_least: 2 %}

                <div class="superupsell-card" style="display:flex;align-items:center;gap:12px;border:1px solid {{ offer.borderColor | default: '#E0E0E0' }};border-radius:{{ card_radius }}px;padding:10px 12px;background:#fff;">
                  {% if offer.showImage and prod.featured_image %}
                    <img src="{{ prod.featured_image | image_url: width: 128 }}" alt="{{ prod.featured_image.alt | escape }}" width="64" height="64" loading="lazy" style="width:64px;height:64px;object-fit:cover;border-radius:{{ img_radius }}px;min-width:64px;">
                  {% endif %}

                  <div style="flex:1;min-width:0;">
                    <div style="font-size:{{ offer.textSize | default: 14 }}px;font-weight:500;color:#1a1a1a;">{{ prod.title }}</div>
                    <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
                      <span style="font-weight:600;color:#1a1a1a;">{{ discounted_price | money }}</span>
                      {% if offer.discountPercentage > 0 %}
                        <span style="text-decoration:line-through;color:#999;">{{ original_price | money }}</span>
                      {% endif %}
                    </div>
                  </div>

                  <button class="superupsell-add-btn" data-variant-id="{{ first_variant.id }}" style="background:{{ offer.buttonColor | default: '#000' }};color:#fff;border:none;border-radius:{{ btn_radius }}px;padding:8px 14px;font-size:{{ offer.buttonSize | default: 14 }}px;font-weight:500;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;">
                    <span style="font-size:{{ offer.buttonSize | default: 14 | plus: 2 }}px;line-height:1;">+</span>
                    {{ offer.buttonText | default: 'Add' }}
                  </button>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <script src="{{ 'superupsell.js' | asset_url }}" defer></script>
    {% endif %}
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Popup Upsell",
  "target": "body",
  "settings": [
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Show popup after (seconds)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
