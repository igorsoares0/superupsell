generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shopify Session (required by @shopify/shopify-app-session-storage-prisma) ───

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── Enums ───

enum Surface {
  product_page
  popup
  cart
}

enum TargetMode {
  all_products
  collections
  specific_products
}

enum Layout {
  vertical
  slider
}

enum CardMode {
  button
  checkbox
}

enum EventType {
  impression
  click
  conversion
  revenue
}

enum SubscriptionStatus {
  trialing
  active
  canceled
  past_due
}

// ─── UpsellOffer (FR-010) ───

model UpsellOffer {
  id                 String   @id @default(cuid())
  shop               String
  surface            Surface
  upsellName         String
  discountLabel      String
  isActive           Boolean  @default(false)
  targetMode         TargetMode
  discountPercentage Decimal  @db.Decimal(5, 2)
  showVariants       Boolean  @default(false)
  showImage          Boolean  @default(true)
  layout             Layout   @default(vertical)
  cardMode           CardMode @default(button)
  showButton         Boolean  @default(true)
  bundleWithMainProduct Boolean @default(false)
  titleText          String   @default("You may also like")
  buttonText         String   @default("Add to cart")
  buttonColor        String   @default("#000000")
  buttonTextColor    String   @default("#FFFFFF")
  backgroundColor    String   @default("#FFFFFF")
  textColor          String   @default("#1A1A1A")
  borderColor        String   @default("#E0E0E0")
  titleSize          Int      @default(18)
  textSize           Int      @default(14)
  buttonSize         Int      @default(14)
  cornerRadius       Int      @default(8)
  shopifyDiscountId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  targets  UpsellOfferTarget[]
  products UpsellOfferProduct[]
  events   AnalyticsEvent[]

  @@index([shop, surface])
  @@index([shop, isActive])
}

// ─── UpsellOfferTarget (FR-020) ───

model UpsellOfferTarget {
  id         String @id @default(cuid())
  offerId    String
  targetType String // "collection" | "product"
  targetId   String // Shopify GID

  offer UpsellOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

// ─── UpsellOfferProduct ───

model UpsellOfferProduct {
  id         String  @id @default(cuid())
  offerId    String
  productId  String  // Shopify GID
  variantIds Json?   // optional array of variant GIDs
  position   Int     @default(0)

  offer UpsellOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

// ─── AnalyticsEvent (FR-100) ───

model AnalyticsEvent {
  id        String    @id @default(cuid())
  shop      String
  offerId   String?
  surface   Surface
  eventType EventType
  amount    Decimal?  @db.Decimal(12, 2)
  currency  String?
  metadata  Json?
  createdAt DateTime  @default(now())

  offer UpsellOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([shop, surface])
  @@index([createdAt])
}

// ─── DailyMetric (aggregated analytics) ───

model DailyMetric {
  id          String  @id @default(cuid())
  shop        String
  surface     Surface
  day         DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)

  @@unique([shop, surface, day])
  @@index([shop, day])
}

// ─── BillingSubscription (FR-110) ───

model BillingSubscription {
  id                  String             @id @default(cuid())
  shop                String             @unique
  planCode            String             @default("pro_monthly")
  status              SubscriptionStatus @default(trialing)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  shopifyChargeId     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}
